{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "RFU is your go-to fishing mod, we have many useful fishing features and even a party finder!",
  "authors": [
    "Riccio"
  ],
  "contact": {
    "homepage": "https://rfu.glitchdev.cloud/",
    "sources": "https://github.com/Ricciow/RiccioFishingUtils-Modern",
    "discord": "https://discord.gg/JfrXm6TqXz"
  },
  "license": "GPL-3.0-or-later",
  "icon": "assets/rfu/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [],
    "client": [
      {
        "adapter": "kotlin",
        "value": "cloud.glitchdev.rfu.RiccioFishingUtils"
      }
    ]
  },
  "mixins": ["rfu.mixins.json"],
  "accessWidener": "rfu.accesswidener",
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "${minecraft}",
    "fabric-language-kotlin": ">=${fabric_language_kotlin}",
    "hypixel-mod-api": ">=${hypixel_mod_api}"
  },
  "custom": {
    "modmenu": {
      "links": {
        "Discord": "https://discord.gg/JfrXm6TqXz"
      }
    }
  }
}